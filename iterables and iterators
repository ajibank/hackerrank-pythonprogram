from itertools import combinations
N = int(input())
letters = input().split()
K = int(input())
combos = list(combinations(range(1, N + 1), K))
count_with_a = 0
for combo in combos:
    for index in combo:
        if letters[index - 1] == 'a':
            count_with_a += 1
            break

print(round(count_with_a / len(combos), 4))
