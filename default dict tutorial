from collections import defaultdict

if __name__ == "__main__":
    n, m = map(int, input().split())

    A = []
    B = defaultdict(list)

    for _ in range(n):
        A.append(input())

    for index, key in enumerate(A):
        B[key].append(index + 1)

    for _ in range(m):
        print(" ".join(str(index) for index in B.get(input(), [-1])))
