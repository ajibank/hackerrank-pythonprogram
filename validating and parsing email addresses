import re
import email.utils

def validate_emails():
    try:
        n = int(input())
    except EOFError:
        return
        
    for _ in range(n):
        line = input()
        name, email_addr = email.utils.parseaddr(line)
        pattern = r"^[a-zA-Z][\w\.-]+@[a-zA-Z]+\.[a-zA-Z]{1,3}$"
        
        if re.match(pattern, email_addr):
            print(email.utils.formataddr((name, email_addr)))

validate_emails()
