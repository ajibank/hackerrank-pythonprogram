from collections import deque
import sys
n=int(sys.stdin.readline())
d=deque()
for _ in range(n):
    command_input = sys.stdin.readline().split()
    method = command_input[0]
    
    if len(command_input) > 1:
        value = command_input[1]
        getattr(d, method)(value)
    else:
        getattr(d, method)()
print(*(d))
